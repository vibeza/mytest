# Конфигурация приложения
APP_NAME=MyApp
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000

# Параметры базы данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=root
DB_PASSWORD=

# Параметры кэша
CACHE_DRIVER=file
CACHE_TTL=3600

# Параметры почты
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@myapp.com

# API ключи
API_KEY=
SECRET_KEY=

# Логирование
LOG_LEVEL=debug
LOG_CHANNEL=single
