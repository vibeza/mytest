# uploads/
# documents/
# rag-documents/

# Временные файлы обработки документов
temp-documents/
tmp-uploads/
*.tmp
*.temp

# ============================================
# Backup & Dumps
# ============================================
backups/
*.bak
*.backup
*.old
*.orig

# ============================================
