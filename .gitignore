# ============================================
.env
.env.example
.env.local
.env.*.local
.env.production
.env.development
*.env

# API Keys & Secrets
secrets/
vault/
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx

# ============================================
# Python Backend (FastAPI Microservices)
# ============================================
# Virtual environments
venv/
env/
ENV/
.venv/
.pyenv/
virtualenv/
__pypackages__/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.prof

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Celery
celerybeat-schedule
celerybeat.pid

# ============================================
# Node.js / Next.js Frontend
# ============================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next.js
.next/
out/
next-env.d.ts

# Build outputs
dist/
build/
*.tsbuildinfo

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# PWA
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

